# Clerk authentication (manage via https://dashboard.clerk.com/)
# Required for sign in, JWT, and API calls
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your-clerk-publishable-key"
CLERK_SECRET_KEY="your-clerk-secret-key"

# Clerk redirect URLs
# Sign-in page path (custom page)
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/login"

# FORCE redirect URLs - ALWAYS redirect here after auth (ignores redirect_url query param)
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL="/dashboard"
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL="/dashboard"

# Google OAuth is managed in Clerk dashboard—do not set GOOGLE_CLIENT_ID/SECRET here.

# Backend API
NEXT_PUBLIC_API_URL="http://localhost:8000"

# Neon PostgreSQL (server-side only — used by Drizzle ORM via @neondatabase/serverless)
# Obtain from your Neon project dashboard: https://neon.tech/docs/connect/connect-from-any-app
DATABASE_URL="postgresql://user:password@ep-xxx-xxx-xxxx.us-east-2.aws.neon.tech/clarift?sslmode=require"


NEXT_PUBLIC_R2_BUCKET_URL=your-bucket.r2.cloudflarestorage.com

R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name