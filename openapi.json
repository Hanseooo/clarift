{
  "openapi": "3.1.0",
  "info": {
    "title": "Clarift API",
    "version": "1.0.0"
  },
  "paths": {
    "/api/v1/auth/sync": {
      "post": {
        "tags": [
          "auth"
        ],
        "summary": "Sync User",
        "description": "Upsert user from NextAuth JWT token.\nCalled by frontend after successful OAuth login.",
        "operationId": "sync_user_api_v1_auth_sync_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SyncRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/auth/me": {
      "get": {
        "tags": [
          "auth"
        ],
        "summary": "Get Current User Profile",
        "description": "Get current user profile using JWT from Authorization header.",
        "operationId": "get_current_user_profile_api_v1_auth_me_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/documents/upload": {
      "post": {
        "tags": [
          "documents"
        ],
        "summary": "Upload Document",
        "description": "Upload a study document (PDF, image, text) for processing.\n\nCreates a Document record, a Job record, and dispatches an ARQ job.\nReturns IDs for polling.",
        "operationId": "upload_document_api_v1_documents_upload_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_upload_document_api_v1_documents_upload_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/summaries": {
      "post": {
        "tags": [
          "summaries"
        ],
        "summary": "Create Summary",
        "description": "Request a summary for a given document.\n\nCreates a pending Summary record and a Job, then triggers the summary chain.\nReturns the summary ID and job ID for polling.",
        "operationId": "create_summary_api_v1_summaries_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateSummaryRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/quizzes": {
      "post": {
        "tags": [
          "quizzes"
        ],
        "summary": "Create Quiz",
        "description": "Request a quiz for a given document.\n\nCreates a pending Quiz record, then triggers the quiz chain.\nReturns the quiz ID and weak topics.",
        "operationId": "create_quiz_api_v1_quizzes_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateQuizRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateQuizResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/quizzes/attempts": {
      "post": {
        "tags": [
          "quizzes"
        ],
        "summary": "Submit Attempt",
        "description": "Submit a quiz attempt and get results.\n\nCreates a QuizAttempt record, calculates score, updates topic performance.\nReturns score and weak topics.",
        "operationId": "submit_attempt_api_v1_quizzes_attempts_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SubmitAttemptRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SubmitAttemptResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/practice": {
      "post": {
        "tags": [
          "practice"
        ],
        "summary": "Create Practice",
        "description": "Request targeted practice drills for weak topics.\n\nCreates a PracticeSession record and returns generated drills.",
        "operationId": "create_practice_api_v1_practice_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePracticeRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreatePracticeResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/chat": {
      "post": {
        "tags": [
          "chat"
        ],
        "summary": "Chat",
        "description": "Ask a question about uploaded documents.\n\nUses grounded chat chain to retrieve relevant chunks and generate answer.",
        "operationId": "chat_api_v1_chat_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ChatRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ChatResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        },
        "security": [
          {
            "HTTPBearer": []
          }
        ]
      }
    },
    "/api/v1/jobs/{job_id}/stream": {
      "get": {
        "tags": [
          "jobs"
        ],
        "summary": "Stream Job Progress",
        "description": "Stream Server-Sent Events (SSE) for job status updates.\nFrontend polls this endpoint to show real‑time progress.",
        "operationId": "stream_job_progress_api_v1_jobs__job_id__stream_get",
        "security": [
          {
            "HTTPBearer": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/health": {
      "get": {
        "summary": "Health",
        "operationId": "health_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Body_upload_document_api_v1_documents_upload_post": {
        "properties": {
          "file": {
            "type": "string",
            "contentMediaType": "application/octet-stream",
            "title": "File"
          }
        },
        "type": "object",
        "required": [
          "file"
        ],
        "title": "Body_upload_document_api_v1_documents_upload_post"
      },
      "ChatRequest": {
        "properties": {
          "document_id": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Document Id"
          },
          "question": {
            "type": "string",
            "title": "Question"
          }
        },
        "type": "object",
        "required": [
          "question"
        ],
        "title": "ChatRequest",
        "description": "Request body for chat endpoint."
      },
      "ChatResponse": {
        "properties": {
          "answer": {
            "type": "string",
            "title": "Answer"
          },
          "citations": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Citations"
          },
          "relevant_chunks": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Relevant Chunks"
          }
        },
        "type": "object",
        "required": [
          "answer",
          "citations",
          "relevant_chunks"
        ],
        "title": "ChatResponse",
        "description": "Response from chat endpoint."
      },
      "CreatePracticeRequest": {
        "properties": {
          "weak_topics": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Weak Topics"
          },
          "drill_count": {
            "type": "integer",
            "title": "Drill Count",
            "default": 5
          }
        },
        "type": "object",
        "required": [
          "weak_topics"
        ],
        "title": "CreatePracticeRequest",
        "description": "Request body for creating a practice session."
      },
      "CreatePracticeResponse": {
        "properties": {
          "practice_id": {
            "type": "string",
            "title": "Practice Id"
          },
          "drills": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "type": "array",
            "title": "Drills"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "practice_id",
          "drills",
          "message"
        ],
        "title": "CreatePracticeResponse",
        "description": "Response after creating a practice session."
      },
      "CreateQuizRequest": {
        "properties": {
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "question_count": {
            "type": "integer",
            "title": "Question Count",
            "default": 5
          },
          "auto_mode": {
            "type": "boolean",
            "title": "Auto Mode",
            "default": true
          }
        },
        "type": "object",
        "required": [
          "document_id"
        ],
        "title": "CreateQuizRequest",
        "description": "Request body for creating a quiz."
      },
      "CreateQuizResponse": {
        "properties": {
          "quiz_id": {
            "type": "string",
            "title": "Quiz Id"
          },
          "message": {
            "type": "string",
            "title": "Message"
          },
          "weak_topics": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Weak Topics"
          }
        },
        "type": "object",
        "required": [
          "quiz_id",
          "message",
          "weak_topics"
        ],
        "title": "CreateQuizResponse",
        "description": "Response after creating a quiz."
      },
      "CreateSummaryRequest": {
        "properties": {
          "document_id": {
            "type": "string",
            "title": "Document Id"
          },
          "format": {
            "type": "string",
            "title": "Format",
            "default": "bullet"
          }
        },
        "type": "object",
        "required": [
          "document_id"
        ],
        "title": "CreateSummaryRequest",
        "description": "Request body for creating a summary."
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "SubmitAttemptRequest": {
        "properties": {
          "quiz_id": {
            "type": "string",
            "title": "Quiz Id"
          },
          "answers": {
            "additionalProperties": {
              "type": "string"
            },
            "type": "object",
            "title": "Answers"
          }
        },
        "type": "object",
        "required": [
          "quiz_id",
          "answers"
        ],
        "title": "SubmitAttemptRequest",
        "description": "Request body for submitting a quiz attempt."
      },
      "SubmitAttemptResponse": {
        "properties": {
          "attempt_id": {
            "type": "string",
            "title": "Attempt Id"
          },
          "score": {
            "type": "number",
            "title": "Score"
          },
          "weak_topics": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Weak Topics"
          },
          "message": {
            "type": "string",
            "title": "Message"
          }
        },
        "type": "object",
        "required": [
          "attempt_id",
          "score",
          "weak_topics",
          "message"
        ],
        "title": "SubmitAttemptResponse",
        "description": "Response after submitting an attempt."
      },
      "SyncRequest": {
        "properties": {
          "token": {
            "type": "string",
            "title": "Token"
          }
        },
        "type": "object",
        "required": [
          "token"
        ],
        "title": "SyncRequest",
        "description": "Request body for auth/sync endpoint."
      },
      "UserResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id"
          },
          "email": {
            "type": "string",
            "title": "Email"
          },
          "name": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          },
          "image": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Image"
          },
          "tier": {
            "type": "string",
            "title": "Tier"
          }
        },
        "type": "object",
        "required": [
          "id",
          "email",
          "name",
          "image",
          "tier"
        ],
        "title": "UserResponse",
        "description": "User profile response."
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    },
    "securitySchemes": {
      "HTTPBearer": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}