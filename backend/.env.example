APP_ENV=development
SECRET_KEY=changeme-to-production-random-value
DATABASE_URL=postgresql+asyncpg://username:password@host:port/dbname
REDIS_URL=redis://localhost:6379/0

# Clerk Auth (required for verifying frontend-issued JWTs)
# Get these from Clerk dashboard > API Keys
CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key # Used for JWT verification and Clerk API fetch (backend only, do not expose!)
# Clerk JWKS/Issuer: used for backend JWT verification
# Set to your Clerk instance's domain, e.g.:
# CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
CLERK_JWKS_URL=https://your-clerk-domain.clerk.accounts.dev/.well-known/jwks.json
# Clerk JWT ISSUER (required for backend auth):
# Set this to your Clerk instance's URL (see dashboard “API & JWT” tab)
CLERK_ISSUER=https://your-clerk-domain.clerk.accounts.dev

GOOGLE_API_KEY=your-gemini-api-key
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=your-bucket-name
PAYMONGO_SECRET_KEY=sk_test_xxx
PAYMONGO_WEBHOOK_SECRET=whsec_xxx
SENTRY_DSN=
